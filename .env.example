# Copy to `.env` and fill in. `.env` is gitignored; this template is not.
#
#   cp .env.example .env
#   ./scripts/fetch_sample.sh
#
# The keys are only ever read by scripts/fetch_sample.sh, which runs once to
# fetch the Stage 1 sample. The Rust binary never reads them and has no network
# access at all — it reads the saved payloads off disk. That is deliberate
# (design.md Decision 12).

# https://alpaca.markets -> Dashboard -> API Keys -> Generate New Key
# A free paper-trading account is enough; we only read market data.
# The secret is shown ONCE at generation time.
APCA_API_KEY_ID=
APCA_API_SECRET_KEY=

# https://massive.com -> Dashboard
MASSIVE_API_KEY=

# GDELT needs no key. It is open data.
